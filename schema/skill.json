{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "_key": {
      "$ref": "./components/key.json"
    },
    "_id": {
      "$ref": "./components/id.json"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "skill"
    },
    "img": {
      "$ref": "./components/img.json"
    },
    "system": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./components/common.json"
        }
      ],
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 0
        },
        "stat": {
          "type": "string",
          "enum": [
            "int",
            "ref",
            "dex",
            "tech",
            "cool",
            "will",
            "move",
            "body",
            "luck",
            "emp"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "awarenessSkills",
            "bodySkills",
            "controlSkills",
            "educationSkills",
            "fightingSkills",
            "performanceSkills",
            "rangedweaponSkills",
            "socialSkills",
            "techniqueSkills"
          ]
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "typical",
            "difficult",
            "role"
          ]
        },
        "skillType": {
          "type": "string",
          "enum": [
            "generic",
            "language",
            "localExpert",
            "martialArt",
            "playInstrument",
            "science"
          ]
        },
        "core": {
          "type": "boolean"
        },
        "basic": {
          "type": "boolean"
        }
      },
      "required": [
        "level",
        "core",
        "basic"
      ]
    },
    "effects": {
      "type": "array",
      "items": {
        "$ref": "./components/effect.json"
      }
    },
    "folder": {
      "type": [
        "string",
        "null"
      ]
    },
    "sort": {
      "type": "integer"
    },
    "ownership": {
      "type": "object"
    },
    "flags": {
      "type": "object"
    },
    "_stats": {
      "$ref": "./components/stats.json"
    }
  },
  "required": [
    "_id",
    "_key",
    "effects",
    "flags",
    "folder",
    "name",
    "ownership",
    "sort",
    "system",
    "type"
  ]
}
