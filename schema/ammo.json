{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "_key": {
      "$ref": "./components/key.json"
    },
    "_id": {
      "$ref": "./components/id.json"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "ammo"
    },
    "img": {
      "$ref": "./components/img.json"
    },
    "system": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./components/common.json"
        },
        {
          "$ref": "./components/installable.json"
        },
        {
          "$ref": "./components/physical.json"
        },
        {
          "$ref": "./components/stackable.json"
        },
        {
          "$ref": "./components/valuable.json"
        }
      ],
      "properties": {
        "ablationValue": {
          "type": "integer",
          "minimum": 0
        },
        "overrides": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "autofire": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "minimum": {
                  "type": "integer",
                  "minimum": 0
                },
                "mode": {
                  "type": "string",
                  "enum": [
                    "none",
                    "set",
                    "modify"
                  ]
                },
                "value": {
                  "type": "integer"
                }
              },
              "required": [
                "minimum",
                "value"
              ]
            },
            "damage": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "minimum": {
                  "type": "string"
                },
                "mode": {
                  "type": "string",
                  "enum": [
                    "none",
                    "set",
                    "modify"
                  ]
                },
                "value": {
                  "type": "string"
                }
              }
            },
            "crit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "override": {
                  "type": "boolean"
                },
                "threshold": {
                  "type": "integer",
                  "minimum": 0
                },
                "count": {
                  "type": "integer",
                  "minimum": 0
                },
                "bonus": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": [
                "override",
                "threshold",
                "count",
                "bonus"
              ]
            }
          },
          "required": [
            "autofire",
            "damage",
            "crit"
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "basic",
            "acid",
            "armorPiercing",
            "biotoxin",
            "emp",
            "expansive",
            "flashbang",
            "incendiary",
            "poison",
            "rubber",
            "sleep",
            "smart",
            "smoke",
            "teargas",
            "special"
          ]
        },
        "variety": {
          "type": "string",
          "enum": [
            "arrow",
            "battery",
            "grenade",
            "heavyPistol",
            "medPistol",
            "paintball",
            "rifle",
            "rocket",
            "shotgunShell",
            "shotgunSlug",
            "vHeavyPistol",
            "custom"
          ]
        }
      },
      "required": [
        "ablationValue",
        "overrides"
      ]
    },
    "effects": {
      "type": "array",
      "items": {
        "$ref": "./components/effect.json"
      }
    },
    "folder": {
      "type": [
        "string",
        "null"
      ]
    },
    "sort": {
      "type": "integer"
    },
    "ownership": {
      "type": "object"
    },
    "flags": {
      "type": "object"
    },
    "_stats": {
      "$ref": "./components/stats.json"
    }
  },
  "required": [
    "_id",
    "_key",
    "effects",
    "flags",
    "folder",
    "name",
    "ownership",
    "sort",
    "system",
    "type"
  ]
}
