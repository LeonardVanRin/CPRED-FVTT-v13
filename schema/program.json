{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "_key": {
      "$ref": "./components/key.json"
    },
    "_id": {
      "$ref": "./components/id.json"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "program"
    },
    "img": {
      "$ref": "./components/img.json"
    },
    "system": {
      "type": "object",
      "allOf": [
        {
          "$ref": "./components/common.json"
        },
        {
          "$ref": "./components/effects.json"
        },
        {
          "$ref": "./components/installable.json"
        },
        {
          "$ref": "./components/valuable.json"
        }
      ],
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "antipersonnelattacker",
            "antiprogramattacker",
            "booster",
            "defender",
            "blackice"
          ]
        },
        "blackIceType": {
          "type": "string",
          "enum": [
            "antipersonnel",
            "antiprogram",
            "other"
          ]
        },
        "prototypeActor": {
          "type": "string"
        },
        "interface": {
          "type": "integer",
          "minimum": 0
        },
        "isRezzed": {
          "type": "boolean"
        },
        "damage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "standard": {
              "type": "string"
            },
            "blackIce": {
              "type": "string"
            }
          }
        },
        "per": {
          "type": "integer",
          "minimum": 0
        },
        "spd": {
          "type": "integer",
          "minimum": 0
        },
        "atk": {
          "type": "integer",
          "minimum": 0
        },
        "def": {
          "type": "integer",
          "minimum": 0
        },
        "rez": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max": {
              "type": "integer",
              "minimum": 0
            },
            "transactions": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "value": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "max",
            "transactions",
            "value"
          ]
        }
      },
      "required": [
        "interface",
        "isRezzed",
        "damage",
        "per",
        "spd",
        "atk",
        "def",
        "rez"
      ]
    },
    "effects": {
      "type": "array",
      "items": {
        "$ref": "./components/effect.json"
      }
    },
    "folder": {
      "type": [
        "string",
        "null"
      ]
    },
    "sort": {
      "type": "integer"
    },
    "ownership": {
      "type": "object"
    },
    "flags": {
      "type": "object"
    },
    "_stats": {
      "$ref": "./components/stats.json"
    }
  },
  "required": [
    "_id",
    "_key",
    "effects",
    "flags",
    "folder",
    "name",
    "ownership",
    "sort",
    "system",
    "type"
  ]
}
