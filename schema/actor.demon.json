{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "_key": {
      "$ref": "./components/key.json"
    },
    "_id": {
      "$ref": "./components/id.json"
    },
    "name": {
      "type": "string"
    },
    "img": {
      "$ref": "./components/img.json"
    },
    "type": {
      "type": "string",
      "const": "demon"
    },
    "system": {
      "type": "object",
      "properties": {
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "rez": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "max": {
                  "type": "integer",
                  "minimum": 0
                },
                "transactions": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "value": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": [
                "max",
                "transactions",
                "value"
              ]
            },
            "interface": {
              "type": "integer",
              "minimum": 0
            },
            "actions": {
              "type": "integer",
              "minimum": 0
            },
            "combatNumber": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "rez",
            "interface",
            "actions",
            "combatNumber"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "stats",
        "notes"
      ],
      "additionalProperties": false
    },
    "prototypeToken": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "number",
          "enum": [
            0,
            10,
            20,
            30,
            40,
            50
          ]
        },
        "actorLink": {
          "type": "boolean"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "texture": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "src": {
              "type": [
                "string",
                "null"
              ]
            },
            "anchorX": {
              "type": "number"
            },
            "anchorY": {
              "type": "number"
            },
            "offsetX": {
              "type": "integer"
            },
            "offsetY": {
              "type": "integer"
            },
            "fit": {
              "type": "string",
              "enum": [
                "fill",
                "contain",
                "cover",
                "width",
                "height"
              ]
            },
            "scaleX": {
              "type": "number"
            },
            "scaleY": {
              "type": "number"
            },
            "rotation": {
              "type": "number",
              "minimum": 0,
              "maximum": 360
            },
            "tint": {
              "type": "string"
            },
            "alphaThreshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "required": [
            "src",
            "anchorX",
            "anchorY",
            "offsetX",
            "offsetY",
            "fit",
            "scaleX",
            "scaleY",
            "rotation",
            "tint",
            "alphaThreshold"
          ]
        },
        "lockRotation": {
          "type": "boolean"
        },
        "rotation": {
          "type": "number",
          "minimum": 0,
          "maximum": 360
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "disposition": {
          "type": "number",
          "enum": [
            -2,
            -1,
            0,
            1
          ]
        },
        "displayBars": {
          "type": "number",
          "enum": [
            0,
            10,
            20,
            30,
            40,
            50
          ]
        },
        "bar1": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "attribute": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "attribute"
          ]
        },
        "bar2": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "attribute": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "attribute"
          ]
        },
        "light": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "negative": {
              "type": "boolean"
            },
            "priority": {
              "type": "integer",
              "minimum": 0
            },
            "alpha": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "angle": {
              "type": "number",
              "minimum": 0,
              "maximum": 360
            },
            "bright": {
              "type": "number",
              "minimum": 0
            },
            "color": {
              "type": [
                "string",
                "null"
              ]
            },
            "coloration": {
              "type": [
                "integer",
                "null"
              ]
            },
            "dim": {
              "type": "number",
              "minimum": 0
            },
            "attenuation": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "luminosity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "saturation": {
              "type": "number",
              "minimum": -1,
              "maximum": 1
            },
            "contrast": {
              "type": "number",
              "minimum": -1,
              "maximum": 1
            },
            "shadows": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "animation": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "type": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "speed": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "intensity": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 10
                },
                "reverse": {
                  "type": "boolean"
                }
              },
              "required": [
                "speed",
                "intensity",
                "reverse"
              ]
            },
            "darkness": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "min": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "max": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              },
              "required": [
                "min",
                "max"
              ]
            }
          },
          "required": [
            "negative",
            "priority",
            "alpha",
            "angle",
            "bright",
            "coloration",
            "dim",
            "attenuation",
            "luminosity",
            "saturation",
            "contrast",
            "shadows",
            "animation",
            "darkness"
          ]
        },
        "sight": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "range": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            "angle": {
              "type": "number",
              "minimum": 0,
              "maximum": 360
            },
            "visionMode": {
              "type": "string"
            },
            "color": {
              "type": [
                "string",
                "null"
              ]
            },
            "attenuation": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "brightness": {
              "type": "number",
              "minimum": -1,
              "maximum": 1
            },
            "saturation": {
              "type": "number",
              "minimum": -1,
              "maximum": 1
            },
            "contrast": {
              "type": "number",
              "minimum": -1,
              "maximum": 1
            }
          },
          "required": [
            "enabled",
            "range",
            "angle",
            "visionMode",
            "attenuation",
            "brightness",
            "saturation",
            "contrast"
          ]
        },
        "detectionModes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string"
              },
              "enabled": {
                "type": "boolean"
              },
              "range": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0
              }
            },
            "required": [
              "enabled",
              "range"
            ]
          }
        },
        "occludable": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "radius": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": [
            "radius"
          ]
        },
        "ring": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "colors": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "ring": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "background": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            },
            "effects": {
              "type": "integer",
              "minimum": 0,
              "maximum": 8388607
            },
            "subject": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "scale": {
                  "type": "number",
                  "minimum": 0.5
                },
                "texture": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "scale"
              ]
            }
          },
          "required": [
            "enabled",
            "colors",
            "effects",
            "subject"
          ]
        },
        "turnMarker": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "number",
              "enum": [
                0,
                1,
                2
              ]
            },
            "animation": {
              "type": [
                "string",
                "null"
              ]
            },
            "src": {
              "type": [
                "string",
                "null"
              ]
            },
            "disposition": {
              "type": "boolean"
            }
          },
          "required": [
            "mode",
            "animation",
            "disposition"
          ]
        },
        "movementAction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "walk",
            "fly",
            "swim",
            "burrow",
            "crawl",
            "climb",
            "jump",
            "blink",
            "displace"
          ]
        },
        "flags": {
          "type": "object"
        },
        "randomImg": {
          "type": "boolean"
        },
        "appendNumber": {
          "type": "boolean"
        },
        "prependAdjective": {
          "type": "boolean"
        }
