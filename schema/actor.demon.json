      "required": [
        "name",
        "displayName",
        "actorLink",
        "width",
        "height",
        "texture",
        "lockRotation",
        "rotation",
        "alpha",
        "disposition",
        "displayBars",
        "bar1",
        "bar2",
        "light",
        "sight",
        "detectionModes",
        "occludable",
        "ring",
        "turnMarker",
        "movementAction",
        "flags",
        "randomImg",
        "appendNumber",
        "prependAdjective"
      ]
