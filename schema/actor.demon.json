    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "img": {
            "type": [
              "string",
              "null"
            ]
          },
          "system": {
            "type": "object"
          },
          "effects": {
            "type": "array",
            "items": {
              "$ref": "./components/effect.json"
            }
          },
          "folder": {
            "type": [
              "string",
              "null"
            ]
          },
          "sort": {
            "type": "integer"
          },
          "ownership": {
            "type": "object"
          },
          "flags": {
            "type": "object"
          },
          "_stats": {
            "$ref": "./components/stats.json"
          },
          "_key": {
            "type": "string",
            "pattern": "^!"
          }
        },
        "required": [
          "_id",
          "name",
          "type",
          "system",
          "effects",
          "folder",
          "sort",
          "ownership",
          "flags",
          "_stats"
        ]
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "$ref": "./components/effect.json"
      }
    },
    "folder": {
      "type": [
        "string",
        "null"
      ]
    },
    "sort": {
      "type": "integer"
    },
    "ownership": {
      "type": "object"
    },
    "flags": {
      "type": "object"
    },
    "_stats": {
      "$ref": "./components/stats.json"
    }
  },
  "required": [
    "_id",
    "_key",
    "effects",
    "flags",
    "folder",
    "items",
    "name",
    "ownership",
    "prototypeToken",
    "sort",
    "system",
    "type"
  ]
}
