<div class="item-sheet">
  <div class="item-top-pane">
    {{> "systems/cyberpunk-red-core/templates/item/parts/cpr-item-header-body.hbs" headerBody}}
  </div>

  <div class="item-bottom-pane">
    <div class="item-bottom-tabs-section">
      <nav class="navtabs-item cpr-tabs nav text-semi" data-group="primary">
        <div class="tab-pink-underlay">
          <a class="tab-label text-small tab-indent" data-tab="item-description">
            {{localize "CPR.global.generic.description"}}
          </a>
        </div>
        <div class="tab-pink-underlay">
          <a class="tab-label text-small tab-indent" data-tab="item-settings">
            {{localize "CPR.settings.title"}}
          </a>
        </div>
        {{#if (cprHasTemplate item.type "effects") }}
          <div class="tab-pink-underlay">
            <a class="tab-label text-small tab-indent" data-tab="item-effects">
              {{localize "CPR.itemSheet.effects.effects"}}
            </a>
          </div>
        {{/if}}
      </nav>
    </div>
    <div class="item-bottom-content-section">
      <div class="tab item-description-grid"
           data-group="primary"
           data-tab="item-description">
        {{> "systems/cyberpunk-red-core/templates/item/cpr-item-description.hbs" this}}
      </div>
      <div class="tab item-settings-grid"
           data-group="primary"
           data-tab="item-settings">
        {{> "systems/cyberpunk-red-core/templates/item/cpr-item-settings.hbs" this}}
      </div>
      {{#if (cprHasTemplate item.type "effects") }}
        <div class="tab item-effects-grid"
             data-group="primary"
             data-tab="item-effects">
          {{> "systems/cyberpunk-red-core/templates/item/cpr-item-effects.hbs" this}}
        </div>
      {{/if}}
    </div>
  </div>

</div>
