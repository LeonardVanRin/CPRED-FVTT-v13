<div class="item-settings-tab">
  <div class="item-settings-section">
    <div class="tab item-settings-grid"
         data-group="primary"
         data-tab="item-settings">
      <ol class="items-list">
        {{!-- Item Name --}}
        {{> "systems/cyberpunk-red-core/templates/item/cpr-item-name.hbs" this}}
        {{!-- Settings common to all items --}}
        {{#each item.system.sources as |src index|}}
          <li class="item flexrow">
            <div class="item flexrow setting-name text-nowrap">
              {{localize "CPR.itemSheet.common.source.book"}}
            </div>
            <div class="item flexrow setting-value text-nowrap item-end">
              {{#if ../this.editable }}
                <input name="system.sources.{{index}}.book"
                       type="text"
                       value="{{src.book}}"
                       placeholder="MwtU"/>
              {{else}}
                {{src.book}}
              {{/if}}
            </div>
          </li>
          <li class="item flexrow">
            <div class="item flexrow setting-name text-nowrap">
              {{localize "CPR.itemSheet.common.source.page"}}
            </div>
            <div class="item flexrow setting-value text-nowrap item-end">
              {{#if ../this.editable }}
                <input name="system.sources.{{index}}.page"
                       type="number"
                       value="{{src.page}}"
                       placeholder="123"/>
                <a class="source-action"
                   data-action-type="delete"
                   data-index="{{index}}"><i class="fas fa-trash-can"
   data-tooltip="{{localize "CPR.itemSheet.common.source.delete"}}"></i></a>
              {{else}}
                {{src.page}}
              {{/if}}
            </div>
          </li>
        {{/each}}
        {{#if this.editable }}
          <li class="item flexrow">
            <div class="item flexrow setting-value text-nowrap">
              <a class="source-action"
                 data-action-type="create"><i class="fas fa-circle-plus text-padding-right"></i>{{localize "CPR.itemSheet.common.source.add"}}</a>
            </div>
          </li>
        {{/if}}
        {{#if item.system.quality}}
          {{> "systems/cyberpunk-red-core/templates/item/settings/mixin/cpr-quality.hbs" this}}
        {{/if}}
        {{!-- Hide this item from the document browser --}}
        <li class="item flexrow">
          <div class="item flexrow setting-name text-nowrap">
            {{localize "CPR.itemSheet.common.ignoredByBrowser"}}
          </div>
          <div class="item flexrow setting-value text-nowrap item-end">
            {{#if this.editable}}
              <a class="item-checkbox" data-target="system.ignoredByBrowser">
                <i class="far fa{{#if item.system.ignoredByBrowser}}-check{{/if}}-circle">
                </i>
              </a>
            {{else}}
              <span>
                <i class="far fa{{#if item.system.ignoredByBrowser}}-check{{/if}}-circle">
                </i>
              </span>
            {{/if}}
          </div>
        </li>
        {{!-- Settings from mixins --}}
        {{#each (cprGetTemplates item.type) as |mixin| }}
          {{#if (and (cprCompare mixin "!==" "effects") (cprCompare mixin "!==" "quality"))}}
            {{!-- If it is the attackable mixin and this is either an itemUpgrade or cyberware, let those item types handle if
            the mixin should be displayed or not since they may or may not be attackable --}}
            {{#unless (cprCompare (cprCompare mixin "===" "attackable") "&&" (cprCompare (cprCompare ../item.type "===" "itemUpgrade") "||" (cprCompare ../item.type "===" "cyberware")))}}
              {{> (cprGeneratePartial "systems/cyberpunk-red-core/templates/item/settings/mixin/cpr-VAR.hbs" mixin) ../this}}
            {{/unless}}
          {{/if}}
        {{/each}}
        {{!-- Settings specific to the item type --}}
        {{> (cprGeneratePartial "systems/cyberpunk-red-core/templates/item/settings/cpr-VAR.hbs" item.type) this}}
      </ol>
    </div>
  </div>
</div>
