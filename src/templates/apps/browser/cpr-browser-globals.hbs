<div class="cpr-browser-globals">
  <div class="cpr-browser-field cpr-browser-global-search">
    <input type="text" class="cpr-browser-name-input" value="{{name}}"
      aria-label="{{localize 'CPR.browser.searchPlaceholder'}}"
      placeholder="{{localize 'CPR.browser.searchPlaceholder'}}" />
  </div>

  {{#if isItemContext}}
  <div class="cpr-browser-global-filters">
    <div class="cpr-browser-field">
      <label for="cpr-browser-quality">{{localize "CPR.browser.filter.quality"}}</label>
      <select id="cpr-browser-quality" class="cpr-browser-quality">
        <option value="">{{localize "CPR.browser.compare.any"}}</option>
        {{selectOptions itemQuality selected=quality localize=true}}
      </select>
    </div>

    <div class="cpr-browser-field">
      <label for="cpr-browser-price-min">{{localize "CPR.browser.price.label"}}</label>
      <div class="cpr-browser-field-row">
        <input type="number" id="cpr-browser-price-min" class="cpr-browser-price-min"
          min="0" value="{{priceMin}}"
          aria-label="{{localize 'CPR.browser.price.label'}} {{localize 'CPR.browser.price.min'}}"
          placeholder="{{localize 'CPR.browser.price.min'}}" />
        <input type="number" class="cpr-browser-price-max" min="0" value="{{priceMax}}"
          aria-label="{{localize 'CPR.browser.price.label'}} {{localize 'CPR.browser.price.max'}}"
          placeholder="{{localize 'CPR.browser.price.max'}}" />
      </div>
    </div>

    <div class="cpr-browser-field">
      <label
        for="cpr-browser-price-category-op">{{localize "CPR.browser.priceCategory.label"}}</label>
      <div class="cpr-browser-field-row">
        <select id="cpr-browser-price-category-op" class="cpr-browser-price-category-op"
          aria-label="{{localize 'CPR.browser.priceCategory.label'}}">
          {{selectOptions priceCategoryOps selected=priceCategoryOp localize=true}}
        </select>
        <select class="cpr-browser-price-category-value"
          aria-label="{{localize 'CPR.browser.priceCategory.label'}}">
          <option value=""></option>
          {{selectOptions priceCategories selected=priceCategoryValue localize=true}}
        </select>
      </div>
    </div>
  </div>
  {{/if}}
</div>
